rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user logged in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Get user role safely (only used on collections OTHER than /users)
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    function isStaff() {
      return isSignedIn() && (
        getUserRole() == 'admin' ||
        getUserRole() == 'operator' ||
        getUserRole() == 'agent'
      );
    }

    // Users collection:
    // - Any authenticated user can read/write their OWN document (required for login flow)
    // - Admins can read ALL user documents
    // NOTE: getUserRole() is NOT called here to avoid circular self-referential rule evaluation.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && getUserRole() == 'admin';
    }

    // Appointments:
    // - Anyone can create (public booking form)
    // - Staff can read/update
    match /appointments/{apptId} {
      allow create: if true;
      allow read, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Customers (KYC): Only staff visible
    match /customers/{customerId} {
      allow read, write: if isStaff();
    }

    // Valuations: Staff only
    match /valuations/{valId} {
      allow read, write: if isStaff();
    }

    // Inventory: Staff can read, Admin can write
    match /inventory/{itemId} {
      allow read: if isStaff();
      allow write: if isAdmin() || isStaff(); // agents write inventory during valuation
    }

    // Refinery Batches: Admin only
    match /refinery_batches/{batchId} {
      allow read, write: if isAdmin();
    }

    // Gold Rates: Public read, Admin write
    match /goldRates/{rateId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
